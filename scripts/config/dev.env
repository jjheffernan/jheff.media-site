# Local dev environment (sourced by scripts/dev.sh — not a dotfile secret)
export YEW_FULLSTACK_HOST=0.0.0.0
export YEW_FULLSTACK_PORT=8080
export YEW_FULLSTACK_FORWARD_FRONTEND_URL=http://localhost:8000
export YEW_FULLSTACK_DB_CONNSTR=mongodb://localhost:27017
export YEW_FULLSTACK_DB_NAME=yew-fullstack_dev_local
export RUST_LOG=info

# Photo feed demo (external URLs — nothing stored in repo)
export YEW_FULLSTACK_FEED_PROVIDER=static
export YEW_FULLSTACK_FEED_STATIC_JSON='[{"id":"1","thumbnailUrl":"https://picsum.photos/seed/auto1/800/600","title":"Track still","mediaType":"image"},{"id":"2","thumbnailUrl":"https://picsum.photos/seed/auto2/800/600","title":"Garage detail","mediaType":"image"},{"id":"3","thumbnailUrl":"https://picsum.photos/seed/auto3/800/600","title":"Onboard lap","mediaType":"video","mediaUrl":"https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerBlazes.mp4"}]'

